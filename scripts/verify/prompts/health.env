#!/usr/bin/env bash
# Health check URLs and compose-only probes.
# Sourced by scripts/verify/health.sh after load-env.sh

# Public HTTP checks (all environments)
HEALTH_CHECK_API="${API_PUBLIC_URL}/health"
HEALTH_CHECK_WEB="${WEB_PUBLIC_URL}/"
HEALTH_CHECK_GRAFANA="${GRAFANA_PUBLIC_URL}/api/health"
HEALTH_CHECK_OTEL="${OTEL_COLLECTOR_PUBLIC_URL}/"
HEALTH_CHECK_MINIO="${MINIO_PUBLIC_URL}/minio/health/live"

# Compose-only (local)
HEALTH_CHECK_N8N_CONTAINER="${N8N_CONTAINER_HEALTH_URL:-http://127.0.0.1:5678/healthz}"
HEALTH_CHECK_POSTGRES_USER=lexflow
HEALTH_CHECK_POSTGRES_DB=lexflow
