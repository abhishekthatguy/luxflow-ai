# LexFlow AI — production (AWS ECS)
# Replace {domain} with firm production hostname before use.

LEXFLOW_ENV=production
VERIFY_USE_COMPOSE=false

# --- Public (ALB / CloudFront) ---
WEB_PUBLIC_URL=https://app.lexflow.{domain}
API_PUBLIC_URL=https://api.lexflow.{domain}
GRAFANA_PUBLIC_URL=https://grafana.lexflow.{domain}
OTEL_COLLECTOR_PUBLIC_URL=
MINIO_PUBLIC_URL=
MINIO_CONSOLE_PUBLIC_URL=
RABBITMQ_MGMT_PUBLIC_URL=

# --- Internal (VPC private — ops / n8n only) ---
API_INTERNAL_URL=http://api.lexflow.internal:8000
WEB_INTERNAL_URL=http://web.lexflow.internal:3000
N8N_INTERNAL_URL=http://n8n.lexflow.internal:5678
POSTGRES_INTERNAL_HOST=lexflow-prod.cluster-xxxx.us-east-1.rds.amazonaws.com
REDIS_INTERNAL_URL=rediss://lexflow-prod.xxxx.cache.amazonaws.com:6379/0
RABBITMQ_INTERNAL_URL=amqps://lexflow-prod.mq.us-east-1.amazonaws.com:5671/
S3_INTERNAL_ENDPOINT=https://s3.us-east-1.amazonaws.com
OTEL_COLLECTOR_INTERNAL_URL=http://otel-collector.lexflow.internal:4317
TEMPO_INTERNAL_URL=http://tempo.lexflow.internal:3200

# --- Legacy aliases ---
WEB_URL="${WEB_PUBLIC_URL}"
API_URL="${API_PUBLIC_URL}"
GRAFANA_URL="${GRAFANA_PUBLIC_URL}"

# --- App runtime ---
ENVIRONMENT=production
LOG_LEVEL=INFO
CORS_ORIGINS=https://app.lexflow.{domain}
NEXT_PUBLIC_API_URL=https://api.lexflow.{domain}
S3_BUCKET=lexflow-prod-documents
