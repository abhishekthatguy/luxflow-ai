# LexFlow AI — local (Docker Compose)
# Loaded by: source scripts/lib/load-env.sh [local]

LEXFLOW_ENV=local
VERIFY_USE_COMPOSE=true

# --- Public (host machine) ---
WEB_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000
GRAFANA_PUBLIC_URL=http://localhost:3001
OTEL_COLLECTOR_PUBLIC_URL=http://localhost:13133
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_CONSOLE_PUBLIC_URL=http://localhost:9001
RABBITMQ_MGMT_PUBLIC_URL=http://localhost:15672

# --- Internal (Docker Compose network) ---
API_INTERNAL_URL=http://api:8000
WEB_INTERNAL_URL=http://web:3000
N8N_INTERNAL_URL=http://n8n:5678
POSTGRES_INTERNAL_HOST=postgres
REDIS_INTERNAL_URL=redis://redis:6379/0
RABBITMQ_INTERNAL_URL=amqp://guest:guest@rabbitmq:5672/
S3_INTERNAL_ENDPOINT=http://minio:9000
OTEL_COLLECTOR_INTERNAL_URL=http://otel-collector:4317
TEMPO_INTERNAL_URL=http://tempo:3200

# --- Inside-container loopback (health probes) ---
N8N_CONTAINER_HEALTH_URL=http://127.0.0.1:5678/healthz
API_CONTAINER_HEALTH_URL=http://127.0.0.1:8000/health
WEB_CONTAINER_HEALTH_URL=http://127.0.0.1:3000/

# --- Legacy aliases (verify scripts) ---
WEB_URL="${WEB_PUBLIC_URL}"
API_URL="${API_PUBLIC_URL}"
GRAFANA_URL="${GRAFANA_PUBLIC_URL}"

# --- App runtime (matches .env.example) ---
ENVIRONMENT=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
S3_BUCKET=lexflow-local-documents
