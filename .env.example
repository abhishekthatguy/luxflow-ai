# LexFlow AI — local development (full platform stack)
# Copy to .env: cp .env.example .env
#
# URL catalog (local / staging / production): config/environments/
# Verify scripts load: config/environments/${LEXFLOW_ENV}.env

ENVIRONMENT=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://lexflow:lexflow@postgres:5432/lexflow

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Messaging
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Object storage (MinIO locally)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=lexflow
S3_SECRET_KEY=lexflowsecret
S3_BUCKET=lexflow-local-documents

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=lexflow-api

# API
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-production-use-secrets-manager
JWT_ACCESS_TTL_MINUTES=60

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
API_INTERNAL_URL=http://api:8000

# n8n (internal Docker network only)
N8N_WEBHOOK_URL=http://n8n:5678
# Optional — only for scripts/n8n/import-workflows.py (REST API). NOT needed for make n8n-import.
# Create in n8n UI: Settings → API → Create API key → paste here.
# N8N_BASE_URL=http://localhost:5679
# N8N_API_KEY=

# --- Notification Engine ---
MAIL_FROM_NAME=LexFlow AI Workflow Engine
MAIL_FROM_ADDRESS=
MANAGING_PARTNER_EMAIL=Teamballiawala@gmail.com
ATTORNEY_EMAIL=
ASSOCIATE_EMAIL=
PARALEGAL_EMAIL=
SYSTEM_ADMINISTRATOR_EMAIL=clawtbot@gmail.com
TEAMS_WEBHOOK_URL=
NOTIFICATION_WEB_BASE_URL=http://localhost:3000

# Slack team follow-up channel (https://abhishekthatguy.slack.com/archives/C0BF67RKS3Z)
# Delivery: Celery deliver_slack_notification → n8n notification-slack-v1 → Slack
# Option A: Incoming Webhook URL for that channel
SLACK_WEBHOOK_URL=
SLACK_TEAM_CHANNEL_ID=C0BF67RKS3Z
# Option B: Bot OAuth token with chat:write (recommended)
# SLACK_BOT_TOKEN=xoxb-...
# App-level token — Socket Mode only; not required for channel posts
# SLACK_APP_TOKEN=xapp-...
# N8N_NOTIFICATION_SLACK_SLUG=notification-slack-v1

# Admin operational alerts — also CC'd on WF-04 client onboarding staff emails
ADMIN_NOTIFICATION_EMAILS=abhishekthatguy@gmail.com

# Gmail SMTP — system sender (optional; logs only when unset)
# Create an app password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=clawtbot@gmail.com
GMAIL_APP_PASSWORD=

# --- LLM (AI summaries) — Phase 1 local / Phase 2 Azure ---
# Phase 1 dev: Ollama primary; stub is automatic fallback when Ollama is down
LLM_PROVIDER=ollama
LLM_ALLOW_STUB=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_ENABLED=true
EMBEDDING_DIMENSIONS=768

# --- OCR — Phase 1 local (PyMuPDF + PaddleOCR on worker) / Phase 2 Azure DI ---
OCR_PROVIDER=local
OCR_ENABLE_PADDLE=true
# OCR_PROVIDER=azure_di
# AZURE_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
# AZURE_DI_API_KEY=

# Phase 2 production LLM (uncomment for Azure OpenAI)
# LLM_PROVIDER=azure_openai
# LLM_ALLOW_STUB=false
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
