# LexFlow AI — local development (Sprint 1 Phase 1)
# Copy to .env: cp .env.example .env

ENVIRONMENT=local
LOG_LEVEL=INFO

# Database (Compose service names)
DATABASE_URL=postgresql+asyncpg://lexflow:lexflow@postgres:5432/lexflow

# Redis
REDIS_URL=redis://redis:6379/0

# API
CORS_ORIGINS=http://localhost:3000

# Web — browser uses localhost; SSR in container uses api hostname
NEXT_PUBLIC_API_URL=http://localhost:8000
API_INTERNAL_URL=http://api:8000

# Sprint 1 Phase 2 (unused until full stack)
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=lexflow-local-documents
# N8N_WEBHOOK_URL=http://n8n:5678
